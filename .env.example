# Palama env checklist — copy to .env, fill in

# Client
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXX
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=AIzaSy...
VITE_VAPID_PUBLIC_KEY=B...

# Server (Cloudflare Worker)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXX
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXX
VAPID_PUBLIC_KEY=B...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:ops@yourdomain
LOVABLE_API_KEY=lv_...